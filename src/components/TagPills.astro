---
interface Props {
  tags: { name: string; slug: string; count: number }[];
  activeTag?: string | null;
}

const { tags, activeTag } = Astro.props;
---

<div class="btn-group">
  {tags.map((tag) => (
    <a
      href={activeTag === tag.slug ? '/' : `/sites/tag/${tag.slug}/`}
      class={`btn -tag${activeTag === tag.slug ? ' is-active' : ''}`}
    >
      {tag.name}
      <span>{tag.count}</span>
    </a>
  ))}
</div>
