---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Submit your site">
  <div class="content-width">
    <div class="banner">
      <h1>Submit your site</h1>
    </div>
    <div class="intro">
      <p>
        Want to add your Wagtail-powered site to the showcase?
      </p>
      <p>
        Head over to the{' '}
        <a href="https://github.com/wagtail/madewithwagtail">madewithwagtail GitHub repo</a>,
        open an issue, or submit a pull request with your site details.
      </p>
      <p>
        We're happy to feature any site built with Wagtail—just share your site's
        URL, a screenshot, the developer name, and a few tags.
      </p>
    </div>
  </div>
</BaseLayout>
